# Local development environment variables
# Copy this file to `.env` and fill in your real values.

# Claude AI (server-side only — do NOT prefix with EXPO_PUBLIC_)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase (Google sign-in)
# Dashboard: https://supabase.com/dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# Use either name — publishable key (sb_publishable_...) or legacy anon key (eyJ...)
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# --- Google Auth setup checklist ---
#
# 1. Supabase → Authentication → Providers → Google
#    - Enable Google and paste your Google OAuth Client ID + Secret
#
# 2. Google Cloud Console → APIs & Services → Credentials
#    - Create OAuth 2.0 Client ID (Web application)
#    - Authorized redirect URI: https://YOUR-PROJECT.supabase.co/auth/v1/callback
#
# 3. Supabase → Authentication → URL Configuration
#    - Site URL (prod): https://soulmate-ai.expo.app
#    - Redirect URLs (add all that apply):
#        http://localhost:**/**
#        https://soulmate-ai.expo.app/**
#        soulmateai://**
#        exp://**          (required for Expo Go on your phone)
#
# 4. Production (EAS Hosting): create the same Supabase vars with:
#    eas env:create --name EXPO_PUBLIC_SUPABASE_URL --value "..." --environment production
#    eas env:create --name EXPO_PUBLIC_SUPABASE_ANON_KEY --value "..." --environment production
#
# 5. After changing .env, restart Expo: npx expo start --clear
